{
  "name": "scalable-real-time-chat-system",
  "version": "1.0.0",
  "private": true,
  "description": "Production-style monorepo portfolio project for a scalable real-time chat platform.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n shared,api,web -c yellow,cyan,magenta \"npm run dev:shared\" \"npm run dev:api\" \"npm run dev:web\"",
    "dev:shared": "npm run dev -w @chat/shared",
    "dev:api": "npm run dev -w @chat/api",
    "dev:web": "npm run dev -w @chat/web",
    "build": "npm run build:shared && npm run build:api && npm run build:web",
    "build:shared": "npm run build -w @chat/shared",
    "build:api": "npm run build -w @chat/api",
    "build:web": "npm run build -w @chat/web",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "test": "npm run test -w @chat/api",
    "db:generate": "npm run prisma:generate -w @chat/api",
    "db:migrate": "npm run prisma:migrate -w @chat/api",
    "db:seed": "npm run prisma:seed -w @chat/api",
    "docker:up": "docker compose up -d postgres redis",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.10.0",
    "npm": ">=10.2.0"
  }
}
